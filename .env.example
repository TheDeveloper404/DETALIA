# ─────────────────────────────────────────────────────────────────────────────
# DETALIA — variabile de mediu (TEMPLATE)
#
# Copiază în `.env.local` și completează cu valori reale:
#     cp .env.example .env.local
#
# REGULI:
#  - .env.local NU se comite niciodată (e în .gitignore). Acest fișier (.env.example) DA — fără valori reale.
#  - În producție, valorile stau în Vercel (`vercel env`). Sincronizezi local cu `vercel env pull`.
#  - Niciun secret hardcodat în cod. Valorile tunable (TTL-uri etc.) tot aici, nu în sursă.
# ─────────────────────────────────────────────────────────────────────────────


# ── Bază de date (Neon Postgres, via Vercel Marketplace) ─────────────────────
# Connection string-ul pooled de la Neon (Drizzle îl folosește pentru runtime).
DATABASE_URL="postgresql://user:password@host.neon.tech/detalia?sslmode=require"
# Opțional: connection direct (non-pooled), folosit de migrații dacă e nevoie.
# DATABASE_URL_UNPOOLED="postgresql://user:password@host.neon.tech/detalia?sslmode=require"


# ── Auth.js v5 (NextAuth) ─────────────────────────────────────────────────────
# Secret pentru semnarea sesiunilor/tokenurilor. Generează cu: `npx auth secret`
AUTH_SECRET="schimba-ma-cu-un-secret-aleatoriu-lung"
# URL-ul canonic al aplicației (în prod = domeniul real). Local = http://localhost:3000
AUTH_URL="http://localhost:3000"
# Conturi admin/seed: liste de emailuri separate prin virgulă. Un user e admin DOAR dacă
# emailul lui e aici (allowlist, deny-by-default). Admin = user normal + puteri seed/verificare.
ADMIN_EMAILS="admin@exemplu-detalia.ro"


# ── Resend (email: magic link + notificări) ──────────────────────────────────
# Auth.js v5 citește automat AUTH_RESEND_KEY pentru providerul de magic link.
# Aceeași cheie o folosește și SDK-ul Resend pentru notificări (process.env.AUTH_RESEND_KEY).
AUTH_RESEND_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Adresa expeditor verificată pe domeniul deținut (SPF/DKIM configurate în Resend).
EMAIL_FROM="DETALIA <no-reply@exemplu-detalia.ro>"


# ── Vercel Blob (stocare: imagini detalii + thumbnail-uri schiță) ─────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"


# ── Valori tunable (NU hardcoda în cod — vezi convențiile din CLAUDE.md) ──────
# Durata de viață a magic link-ului de login (minute).
MAGIC_LINK_TTL_MINUTES="15"
# Durata de viață a unei invitații de acces în beta închis (ore).
INVITATION_TTL_HOURS="168"            # 168h = 7 zile


# ── Mediu ─────────────────────────────────────────────────────────────────────
# development | production — setat automat de Next/Vercel; rar trebuie suprascris.
# NODE_ENV="development"
