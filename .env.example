# ─────────────────────────────────────────────────────────────────────────────
# DETALIA — variabile de mediu (TEMPLATE)
#
# Copiază în `.env.local` și completează cu valori reale:
#     cp .env.example .env.local
#
# REGULI:
#  - .env.local NU se comite niciodată (e în .gitignore). Acest fișier (.env.example) DA — fără valori reale.
#  - În producție, valorile stau în Vercel (`vercel env`). Sincronizezi local cu `vercel env pull`.
#  - Niciun secret hardcodat în cod. Valorile tunable (TTL-uri etc.) tot aici, nu în sursă.
# ─────────────────────────────────────────────────────────────────────────────


# ── Bază de date (Neon Postgres, via Vercel Marketplace) ─────────────────────
# Connection string-ul pooled de la Neon (Drizzle îl folosește pentru runtime).
DATABASE_URL="postgresql://user:password@host.neon.tech/detalia?sslmode=require"
# Opțional: connection direct (non-pooled), folosit de migrații dacă e nevoie.
# DATABASE_URL_UNPOOLED="postgresql://user:password@host.neon.tech/detalia?sslmode=require"


# ── Auth.js v5 (NextAuth) ─────────────────────────────────────────────────────
# Secret pentru semnarea sesiunilor/tokenurilor. Generează cu: `npx auth secret`
AUTH_SECRET="schimba-ma-cu-un-secret-aleatoriu-lung"
# URL-ul canonic al aplicației (în prod = domeniul real). Local = http://localhost:3000
AUTH_URL="http://localhost:3000"
# ── Admin (panou /admin-page) ─────────────────────────────────────────────────
# Login admin = MAGIC LINK pe email, separat de userii platformei (sesiune proprie). CINE e admin =
# allowlist de mai jos (emailuri separate prin virgulă). Doar aceste adrese primesc link valabil.
ADMIN_EMAILS="admin@exemplu-detalia.ro"
# TTL-uri opționale: sesiune admin (ore, default 8) + magic link admin (minute, default 15).
ADMIN_SESSION_TTL_HOURS="8"
ADMIN_LOGIN_TOKEN_TTL_MINUTES="15"


# ── Google OAuth — DEZACTIVAT în MVP ──────────────────────────────────────────
# Pentru MVP login-ul e DOAR magic link (Resend). Providerul Google a fost scos din `lib/auth.ts`.
# Ca să-l reactivezi ulterior: readaugă providerul Google în lib/auth.ts + butonul în auth-form.tsx,
# apoi setează variabilele de mai jos (citite automat de Auth.js v5). Redirect URI autorizat:
#   {AUTH_URL}/api/auth/callback/google  (ex: http://localhost:3000/api/auth/callback/google)
# AUTH_GOOGLE_ID="xxxxxxxx.apps.googleusercontent.com"
# AUTH_GOOGLE_SECRET="GOCSPX-xxxxxxxxxxxx"


# ── Resend (email: magic link + notificări) ──────────────────────────────────
# Auth.js v5 citește automat AUTH_RESEND_KEY pentru providerul de magic link.
# Aceeași cheie o folosește și SDK-ul Resend pentru notificări (process.env.AUTH_RESEND_KEY).
AUTH_RESEND_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Adresa expeditor verificată pe domeniul deținut (SPF/DKIM configurate în Resend).
EMAIL_FROM="DETALIA <no-reply@exemplu-detalia.ro>"


# ── Vercel Blob (stocare: imagini detalii + thumbnail-uri schiță) ─────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"


# ── Valori tunable (NU hardcoda în cod — vezi convențiile din CLAUDE.md) ──────
# Durata de viață a magic link-ului de login (minute).
MAGIC_LINK_TTL_MINUTES="15"


# ── Sentry (observabilitate erori) — OPȚIONAL, no-op complet dacă lipsește ────
# DSN e public (embedat în bundle-ul client) — nu e secret. Fără el, Sentry se dezactivează automat.
# NEXT_PUBLIC_SENTRY_DSN="https://xxxx@oXXXXXX.ingest.de.sentry.io/XXXXXXX"
# Necesare DOAR pt upload de source maps la build (org/proiect din Sentry → Settings). Token = secret.
# SENTRY_ORG="numele-organizatiei"
# SENTRY_PROJECT="numele-proiectului"
# SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxxxxxxxxxxxxxx"


# ── PostHog (analytics + error tracking) — OPȚIONAL, no-op complet dacă lipsește ──
# Token de proiect, public (embedat în bundle-ul client) — nu e secret.
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN="phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Host regional (EU pt DETALIA — useri RO).
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
# Necesare DOAR pt upload de source maps la build (PostHog → Settings → Personal API keys). Token = secret.
# POSTHOG_PERSONAL_API_KEY="phx_xxxxxxxxxxxxxxxxxxxxxxxx"
# POSTHOG_ENV_ID="224228"


# ── Mediu ─────────────────────────────────────────────────────────────────────
# development | production — setat automat de Next/Vercel; rar trebuie suprascris.
# NODE_ENV="development"
