# === Lint / cache build ===
.eslintcache
.turbo/

# === Certificate locale (https dev) ===
*.pem
*.local.key
*.local.crt

# === OS / editor ===
.DS_Store
Thumbs.db
.idea/
*.swp

# === Tooling Claude Code (NU se comite — e setup local, nu cod de produs) ===
.claude/
.agents/
skills-lock.json

# === Continuitate sesiune (local, nu cod de proiect) ===
.remember/

# === Documente care NU se comit (client + arhivă de docs) ===
/documente_client
docs/_archive/

# === CE SE COMITE (exemple, ca să fie clar pentru echipă) ===
# docs/                       -> documentația (ARHITECTURA.md, CHANGELOG.md, etc.)
# CLAUDE.md                   -> specificația de domeniu a proiectului
# .env.example                -> template de env, fără valori reale

